!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_DIR/docker"

if docker compose exec -T phpfpm test -f /var/www/html/bin/magento 2>/dev/null; then
    docker compose exec -u www-data phpfpm php //var/www/html/bin/magento "$@"
else
    echo "Error: Magento binary not found at /var/www/html/bin/magento"
    exit 1
fi
